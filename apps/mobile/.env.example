EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth — create three clients in Google Cloud Console (APIs & Services → Credentials):
#
# 1) Web client (for browser / localhost testing)
#    Authorized JavaScript origins: http://localhost:8081
#    Authorized redirect URIs:      http://localhost:8081/oauthredirect
#
# 2) iOS client — bundle ID: com.kunkshi.split
# 3) Android client — package: com.kunkshi.split + SHA-1 from EAS credentials
#    Get SHA-1: cd apps/mobile/android && ./gradlew signingReport
#    (or keytool -list -v -keystore %USERPROFILE%\.android\debug.keystore -alias androiddebugkey -storepass android)
#
# Also add the same iOS/Android client IDs to apps/api/.env as GOOGLE_IOS_CLIENT_ID / GOOGLE_ANDROID_CLIENT_ID
# so the API can verify ID tokens from those clients.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
