{
  "expo": {
    "name": "Split",
    "slug": "split",
    "version": "1.0.0",
    "entryPoint": "./index.js",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "split",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kunkshi.split",
      "associatedDomains": ["applinks:split.kunkshi.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "Split needs camera access to capture receipt photos.",
        "NSContactsUsageDescription": "Split needs contacts access to add friends to groups.",
        "NSFaceIDUsageDescription": "Split uses Face ID for secure login.",
        "NSMicrophoneUsageDescription": "Split uses the microphone for voice expense entry.",
        "NSSpeechRecognitionUsageDescription": "Split transcribes your voice to parse expenses."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F14"
      },
      "package": "com.kunkshi.split",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "split.kunkshi.com",
              "pathPrefix": "/join-group"
            },
            {
              "scheme": "https",
              "host": "split.kunkshi.com",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "split.kunkshi.com",
              "pathPrefix": "/verify-email"
            },
            {
              "scheme": "https",
              "host": "split.kunkshi.com",
              "pathPrefix": "/forgot-password"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.googleusercontent.apps.563520723268-cmgf0d7unjk36auv4ntqbbb4bhpk7mrt"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_CONTACTS",
        "USE_FINGERPRINT",
        "USE_BIOMETRIC",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 26
          }
        }
      ],
      "expo-speech-recognition",
      [
        "expo-image-picker",
        {
          "photosPermission": "Split needs photo access to attach receipt images."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Split uses contacts to add friends and group members."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Split scans group invite QR codes to join groups."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "77fd71fc-616e-4b99-8af7-5cfb2dbf87e6"
      }
    },
    "owner": "prateeksood"
  }
}
