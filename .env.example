# ─── API Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://split:split_dev_password@localhost:5432/split?schema=public

# Redis (reserved — not used at runtime today; kept for future caching/queues)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=90d

# AI Providers (server-side only — never expose to client)
# Fallback order: Gemini → Grok (xAI) → Groq → OpenRouter
GEMINI_API_KEY=
GROK_API_KEY=
GROK_MODEL=grok-3-mini
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# OAuth — Web client ID used by API to verify tokens
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Storage (optional — for receipt uploads)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

# App URL (password reset links; also allowed as a CORS origin in production)
APP_URL=http://localhost:8081

# Comma-separated admin email addresses (server-side only — never expose to client)
ADMIN_EMAILS=

# Comma-separated browser origins allowed to call the API in production (required for Expo web).
# Example: http://localhost:8081,https://your-expo-web.pages.dev
CORS_ORIGINS=http://localhost:8081

# Email — Resend HTTP API key (get from resend.com, verify your domain)
# Uses HTTPS port 443 — no firewall/port issues unlike SMTP.
RESEND_API_KEY=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Split <support@kunkshi.com>

# Mobile app (Expo public vars — safe for client, apps/mobile/.env)
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
